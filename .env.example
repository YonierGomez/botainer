# Requerido
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Opcional: restringe el acceso a estos User IDs (separados por coma)
# Si se deja vacío, cualquier usuario puede usar el bot
ALLOWED_USERS=123456789,987654321

# Opcional pero recomendado: chat ID donde llegan las notificaciones automáticas
# Sin esto, las notificaciones solo funcionan después de que alguien escriba al bot
# Obtén tu chat ID enviando un mensaje a @userinfobot en Telegram
NOTIFY_CHAT_ID=123456789
