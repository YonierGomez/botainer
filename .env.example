# Telegram Bot Token (required)
# Obtén tu token de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID para notificaciones automáticas (opcional)
# Obtén tu chat ID de @userinfobot
NOTIFY_CHAT_ID=

# IDs de usuarios permitidos (opcional)
# Lista separada por comas de Telegram User IDs
# Si está vacío, todos los usuarios pueden usar el bot
# Ejemplo: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=
